                                  <cv:FillValue>
                                    <cv:Val0>0</cv:Val0>
                                    <cv:Val1>0</cv:Val1>
                                    <cv:Val2>0</cv:Val2>
                                    <cv:Val3>1</cv:Val3>
                                  </cv:FillValue>
                                </Combinator>
                              </Expression>
