                                <PropertyMappings>
                                  <Property Name="Color" />
                                </PropertyMappings>
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="cv:SolidColor">
                                  <cv:Size>
                                    <cv:Width>608</cv:Width>
                                    <cv:Height>608</cv:Height>
                                  </cv:Size>
                                  <cv:Depth>U8</cv:Depth>
                                  <cv:Channels>3</cv:Channels>
                                  <cv:Color>
                                    <cv:Val0>0</cv:Val0>
                                    <cv:Val1>0</cv:Val1>
                                    <cv:Val2>100</cv:Val2>
                                    <cv:Val3>100</cv:Val3>
